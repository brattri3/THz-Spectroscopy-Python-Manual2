% ==================== NOTES / WARNINGS / TIPS ====================
\long\def\note#1{{\color{RoyalBlue}\textbf{Примечание:} #1}}
\long\def\warning#1{{\color{BurntOrange}\textbf{Важно:} #1}}
\long\def\tip#1{{\color{ForestGreen}\textbf{Совет:} #1}}

% ==================== PLACEHOLDERS & SMART FIGURES ====================
\newcommand{\smartfigure}[3]{%
	\begin{figure}[H]
		\centering
		\IfFileExists{images/#1}{%
			\includegraphics[width=0.8\textwidth]{images/#1}%
		}{%
			\fbox{\parbox{0.8\textwidth}{
				\centering
				\vspace{1.5cm}
				\textbf{\textsf{Место для изображения: images/#1}} \\
				\vspace{0.5cm}
				\textit{#2}
				\vspace{1.5cm}
			}}
		}
		\caption{#2}
		\label{#3}
	\end{figure}
}

\newcommand{\placeholderfigure}[2]{%
	\begin{figure}[H]
		\centering
		\fbox{\parbox{0.8\textwidth}{
			\centering
			\vspace{1.5cm}
			\textbf{\textsf{Место для скриншота #1}} \\
			\vspace{0.5cm}
			\textit{#2}
			\vspace{1.5cm}
		}}
		\caption{Скриншот #1}
	\end{figure}
}

