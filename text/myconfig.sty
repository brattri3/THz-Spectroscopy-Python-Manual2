% myconfig.sty
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{myconfig}[2023/12/01 Custom configuration for OPUS-NT documentation]

% ==================== ENGINE DETECTION ====================
\RequirePackage{iftex}

\ifPDFTeX
% Для pdflatex
\RequirePackage[utf8]{inputenc}
\RequirePackage[T2A]{fontenc}
\RequirePackage[english, russian]{babel}
\else
% Для xelatex и lualatex
\RequirePackage{fontspec}
% Используем babel вместо polyglossia — он надёжнее и не требует доп. шрифтов
\RequirePackage[english, russian]{babel}

% Задаём шрифты (используем стандартные системные имена без расширений)
% Если этих шрифтов нет, замените на: Liberation Serif, Liberation Mono, Arial
\setmainfont{Times New Roman}
\setmonofont{Courier New}
\setsansfont{Arial}
\fi

% ==================== BASIC PACKAGES ====================
\RequirePackage{indentfirst}

% ==================== MATH PACKAGES ====================
\RequirePackage{amsmath, amssymb, amsfonts}
\RequirePackage{bm}

% ==================== TABLE SUPPORT ====================
\RequirePackage{tabularx}
\RequirePackage{longtable}
\RequirePackage[table, dvipsnames]{xcolor}
\definecolor{lightgray}{RGB}{240,240,240}

% ==================== GRAPHICS SUPPORT ====================
\RequirePackage{graphicx}
\RequirePackage{float}
\RequirePackage{ifthen}

% ==================== IMAGE SCALING ====================
\newlength{\imgwidth}
\newcommand{\autoscale}[2][0.8]{%
	\settowidth{\imgwidth}{\includegraphics{#2}}%
	\ifdim\imgwidth>#1\textwidth
	\includegraphics[width=#1\textwidth]{#2}%
	\else
	\includegraphics{#2}%
	\fi
}

% ==================== PARAGRAPH SETTINGS ====================
\RequirePackage{setspace}
\onehalfspacing % Полуторный интервал по ГОСТ
\setlength{\parindent}{1.25cm} % Абзацный отступ по ГОСТ
\setlength{\parskip}{0pt} % Без дополнительных отступов между абзацами

% ==================== PAGE LAYOUT ====================
\RequirePackage{geometry}
\geometry{
	left=3cm,
	right=2cm,
	top=2cm,
	bottom=2cm,
	headheight=1cm,
	footskip=1cm
}

% ==================== HEADING FORMATTING ====================
\RequirePackage{titlesec}
\definecolor{headerblue}{RGB}{12, 35, 64}

\titleformat{\section}
{\bfseries\Large\color{headerblue}}
{\thesection}
{1em}
{}

\titleformat{\subsection}
{\bfseries\large\color{headerblue}}
{\thesubsection}
{1em}
{}

\titleformat{\subsubsection}
{\bfseries\color{headerblue}}
{\thesubsubsection}
{1em}
{}

\titlespacing*{\section}{0pt}{18pt plus 4pt minus 2pt}{8pt plus 2pt}
\titlespacing*{\subsection}{0pt}{14pt plus 3pt minus 2pt}{6pt plus 1pt}
\titlespacing*{\subsubsection}{0pt}{10pt plus 2pt minus 2pt}{4pt plus 1pt}

% ==================== LIST SETTINGS ====================
\RequirePackage{enumitem}
\setlist{nosep}
\setlist[itemize]{labelindent=\parindent, leftmargin=*, itemsep=0pt, parsep=0pt, topsep=0pt, partopsep=0pt}
\setlist[enumerate]{labelindent=\parindent, leftmargin=*, itemsep=0pt, parsep=0pt, topsep=0pt, partopsep=0pt}

% Специальное окружение для разбора синтаксиса (абзацы с обратным/выступающим отступом - hanging indent)
\newenvironment{syntaxdesc}{%
	\par\vspace{0.3em}%
	\newcommand{\syntaxitem}[1][]{%
		\par\vspace{0.4em}%
		\hangindent=1.25cm%
		\hangafter=1%
		\noindent\textbf{##1} ~--- %
	}%
	\let\item\syntaxitem
}{%
	\par\vspace{0.5em}%
}
\RequirePackage{multicol}

% ==================== CUSTOM TEXT COMMANDS ====================
\RequirePackage[many]{tcolorbox}
\newtcolorbox{minitaskbox}[1][]{%
	enhanced,
	colback=RoyalBlue!5,
	colframe=RoyalBlue,
	boxrule=1pt,
	arc=4pt,
	left=10pt,
	right=10pt,
	top=10pt,
	bottom=10pt,
	title={\textbf{🔬 Практическое мини-задание}},
	coltitle=RoyalBlue,
	attach boxed title to top left={xshift=10pt, yshift=-10pt},
	boxed title style={colback=white, colframe=RoyalBlue},
	#1
}

\newcommand{\minitask}[1]{%
	\begin{minitaskbox}
		#1
	\end{minitaskbox}
}

\newcommand{\mybold}[1]{%
	\vspace{0.5em}%
	\noindent\textbf{#1}%
	\vspace{0.3em}%
}

% ==================== HYPHENATION SETTINGS ====================
\hyphenpenalty=500
\tolerance=200

% ==================== FIGURE REFERENCES ====================
\newcommand{\figref}[1]{Рисунок~\ref{#1}}

% ==================== CAPTION SETTINGS ====================
\RequirePackage{caption}
\DeclareCaptionLabelSeparator{emdash}{~---~}
\captionsetup{labelsep=emdash}
\captionsetup[figure]{name=Рисунок, justification=centering}
\captionsetup[table]{name=Таблица, justification=raggedright, singlelinecheck=false}

% ==================== COUNTER SETTINGS ====================
\RequirePackage{chngcntr}
\counterwithin{figure}{section}

% ==================== HYPERREFERENCES ====================
\RequirePackage[unicode=true, hidelinks]{hyperref}
\hypersetup{
	colorlinks=true,
	linkcolor=black,
	urlcolor=blue,
	pdftitle={OPUS-NT Documentation},
	pdfauthor={Author},
	bookmarksdepth=3,
	bookmarksnumbered=true
}

% ==================== PAGE NUMBERING ====================
\RequirePackage{etoolbox}
\pretocmd{\tableofcontents}{\clearpage\pagenumbering{gobble}}{}{}
\apptocmd{\tableofcontents}{\clearpage\pagenumbering{arabic}\setcounter{page}{1}}{}{}

% ==================== PREVENT WIDOW/ORPHAN HEADINGS ====================
\RequirePackage{needspace}

% ==================== BILINGUAL HEADINGS WITH EXACT ALIGNMENT ====================
\newcommand{\bilingualsection}[2]{%
	\needspace{15\baselineskip}%
	\section[#1]{\texorpdfstring{#1}{#2}}%
	\vspace{-1.2em}%
	{\par\noindent\hspace{\dimexpr-0.8em\relax}\bfseries\Large #2\par}%
	\vspace{0.3em}%
}

\newcommand{\bilingualsubsection}[2]{%
	\needspace{15\baselineskip}%
	\subsection[#1]{\texorpdfstring{#1}{#2}}%
	\vspace{-1.2em}%
	{\par\noindent\hspace{\dimexpr2.8em\relax}\bfseries\large #2\par}%
	\vspace{0.2em}%
}

\newcommand{\bilingualsubsubsection}[2]{%
	\needspace{10\baselineskip}%
	\subsubsection[#1]{\texorpdfstring{#1}{#2}}%
	\vspace{-0.8em}%
	{\par\noindent\hspace{\dimexpr4em\relax}\bfseries #2\par}%
	\vspace{0.1em}%
}

% ==================== MINTED SETTINGS ====================
\RequirePackage{minted}
\floatstyle{plaintop}
\restylefloat{listing}
\renewcommand{\listingscaption}{Листинг}
\RequirePackage{caption}    % для подписей
\captionsetup[listing]{hypcap=false, labelsep=emdash, justification=raggedright, singlelinecheck=false, skip=-10pt, position=top, labelfont=bf}

\RequirePackage{etoolbox}



\definecolor{mintedbg}{RGB}{245,247,250}
\definecolor{mintedframe}{RGB}{200,205,210}

\setminted{
	baselinestretch=1.2,
	fontsize=\footnotesize,
	tabsize=4,
	breaklines,
	autogobble,
	linenos=true,
	style=friendly,
	numbersep=6pt,
	showspaces=true
}

% Мягкий серый маркер отступа вместо стандартного \textvisiblespace
% Помогает студентам считать уровни вложенности в Python-коде
\makeatletter
\renewcommand{\FancyVerbSpace}{\textcolor[RGB]{200,210,220}{\raisebox{0.3ex}{\scalebox{0.55}{$\bullet$}}}}
\makeatother

% Автоматическое оборачивание всех блоков minted в tcolorbox для сплошной заливки фона
\BeforeBeginEnvironment{minted}{%
	\begin{tcolorbox}[
		enhanced,
		breakable,
		colback=mintedbg,
		colframe=mintedframe,
		boxrule=0.8pt,
		arc=2pt,
		left=6mm,
		right=2mm,
		top=1.5mm,
		bottom=1.5mm,
		boxsep=0mm
	]%
}
\AfterEndEnvironment{minted}{\end{tcolorbox}}

% Автоматическое оборачивание \inputminted в tcolorbox для единообразия
\let\oldinputminted\inputminted
\renewcommand{\inputminted}[3][]{%
	\begin{tcolorbox}[
		enhanced,
		breakable,
		colback=mintedbg,
		colframe=mintedframe,
		boxrule=0.8pt,
		arc=2pt,
		left=6mm,
		right=2mm,
		top=1.5mm,
		bottom=1.5mm,
		boxsep=0mm
	]%
	\oldinputminted[#1]{#2}{#3}%
	\end{tcolorbox}%
}

% Корректировка цвета комментариев для лучшей контрастности на белом фоне листа.
% Исходный блеклый цвет в friendly (0.38, 0.63, 0.69) заменяется на глубокий контрастный сине-зеленый (0.10, 0.29, 0.34) и делается жирным.
\makeatletter
\AtBeginDocument{
	\expandafter\def\csname PYGfriendly@tok@c\endcsname{\let\PYG@it=\relax\def\PYG@tc##1{\textcolor[rgb]{0.10,0.29,0.34}{\textbf{##1}}}}
	\expandafter\def\csname PYGfriendly@tok@ch\endcsname{\let\PYG@it=\relax\def\PYG@tc##1{\textcolor[rgb]{0.10,0.29,0.34}{\textbf{##1}}}}
	\expandafter\def\csname PYGfriendly@tok@cm\endcsname{\let\PYG@it=\relax\def\PYG@tc##1{\textcolor[rgb]{0.10,0.29,0.34}{\textbf{##1}}}}
	\expandafter\def\csname PYGfriendly@tok@cp\endcsname{\let\PYG@it=\relax\def\PYG@tc##1{\textcolor[rgb]{0.10,0.29,0.34}{\textbf{##1}}}}
	\expandafter\def\csname PYGfriendly@tok@cpf\endcsname{\let\PYG@it=\relax\def\PYG@tc##1{\textcolor[rgb]{0.10,0.29,0.34}{\textbf{##1}}}}
	\expandafter\def\csname PYGfriendly@tok@cs\endcsname{\let\PYG@it=\relax\def\PYG@tc##1{\textcolor[rgb]{0.10,0.29,0.34}{\textbf{##1}}}}
	\expandafter\def\csname PYGfriendly@tok@c1\endcsname{\let\PYG@it=\relax\def\PYG@tc##1{\textcolor[rgb]{0.10,0.29,0.34}{\textbf{##1}}}}
	%
	% Корректировка шрифта строк (String tokens) — делаем их жирными (bold) для лучшей читаемости и выразительности.
	\expandafter\def\csname PYGfriendly@tok@s\endcsname{\let\PYG@it=\relax\def\PYG@tc##1{\textcolor[rgb]{0.25,0.44,0.63}{\textbf{##1}}}}
	\expandafter\def\csname PYGfriendly@tok@sa\endcsname{\let\PYG@it=\relax\def\PYG@tc##1{\textcolor[rgb]{0.25,0.44,0.63}{\textbf{##1}}}}
