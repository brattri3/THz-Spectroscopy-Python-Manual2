% ==================== CODE / PATH STYLING WITH NO MANUAL ESCAPING ====================
% Макрос \mycode позволяет писать пути к файлам, переменные и любой код с символами
% подчеркивания (_) напрямую, без ручного экранирования. Работает везде, включая заголовки!
% Для централизованного изменения стиля достаточно поменять определение этого макроса.
\newcommand{\mycode}[1]{\texttt{\detokenize{#1}}}

% ==================== NOTES / WARNINGS / TIPS ====================
\long\def\note#1{%
	\begin{tcolorbox}[colback=RoyalBlue!5!white, colframe=RoyalBlue!75!black, title=\textbf{Примечание}, arc=2mm]
		#1
	\end{tcolorbox}%
}
\long\def\warning#1{%
	\begin{tcolorbox}[colback=BurntOrange!5!white, colframe=BurntOrange!75!black, title=\textbf{Важно}, arc=2mm]
		#1
	\end{tcolorbox}%
}
\long\def\tip#1{%
	\begin{tcolorbox}[colback=ForestGreen!5!white, colframe=ForestGreen!75!black, title=\textbf{Совет}, arc=2mm]
		#1
	\end{tcolorbox}%
}

% ==================== PLACEHOLDERS & SMART FIGURES ====================
\newcommand{\smartfigure}[3]{%
	\begin{figure}[H]
		\centering
		\IfFileExists{images/#1}{%
			\includegraphics[width=0.8\textwidth]{images/#1}%
		}{%
			\fbox{\parbox{0.8\textwidth}{
				\centering
				\vspace{1.5cm}
				\textbf{\textsf{Место для изображения: images/#1}}
				\vspace{1.5cm}
			}}
		}
		\caption{#2}
		\label{#3}
	\end{figure}
}

\newcommand{\placeholderfigure}[2]{%
	\begin{figure}[H]
		\centering
		\fbox{\parbox{0.8\textwidth}{
			\centering
			\vspace{1.5cm}
			\textbf{\textsf{Место для скриншота #1}}
			\vspace{1.5cm}
		}}
		\caption{Скриншот #1}
	\end{figure}
}

