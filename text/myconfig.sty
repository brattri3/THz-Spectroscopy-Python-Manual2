	%
	% Корректировка шрифта строк (String tokens) — делаем их жирными (bold) для лучшей читаемости и выразительности.
	\expandafter\def\csname PYGfriendly@tok@s\endcsname{\let\PYG@it=\relax\def\PYG@tc##1{\textcolor[rgb]{0.25,0.44,0.63}{\textbf{##1}}}}
